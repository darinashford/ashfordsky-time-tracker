# ============================================================================
# Ashford Sky Time Tracker — environment template
# Copy to .env and fill the values marked __paste__. .env is git-ignored.
# ============================================================================

# ---- PRIMARY DB CONNECTION (all services + dashboard use this) --------------
# Supabase Dashboard > Project Settings > Database > Connection string
# ("Session pooler" or "Direct connection"); it includes the password.
#   postgresql://postgres.<ref>:<password>@<host>:5432/postgres?sslmode=require
DATABASE_URL=__paste_supabase_connection_string_here__
TIME_TRACKER_SCHEMA=time_tracker

# ---- Supabase REST (optional; only if you later use supabase-js) ------------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=__paste_anon_key_here__
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=__paste_anon_key_here__

# ---- QBO realm sync (services/qbo-realm-sync; Railway cron) -----------------
# Read-only connection string to the QBO-App connector's DB (Replit's built-in
# Postgres — table qbo_connections). The daily job reads each connected book's
# realmId + company name from here and writes client->realm links into the graph
# above (source_system_links, source_system='qbo'). Only needed on the
# qbo-realm-sync service. Get it from Replit: the QBO-App's DATABASE_URL secret
# (external Postgres URL, sslmode=require).
QBO_APP_DATABASE_URL=__paste_replit_qbo_app_postgres_url_here__

# ---- Weekly rule audit (services/rule-audit; Railway cron, Mondays) ---------
# Posts a short heads-up when a NEW learned rule looks over-broad. Set to an
# incoming webhook (Slack / Teams / Discord, or an email-via-Zapier hook). If
# unset, the job just logs to Railway. DASHBOARD_URL adds a link to /rules.
RULE_ALERT_WEBHOOK_URL=
DASHBOARD_URL=https://time.ashfordsky.com

# ---- Sensor: ActivityWatch local REST API ----------------------------------
ACTIVITYWATCH_URL=http://localhost:5600
SENSOR_MODE=mock          # mock | live

# ---- Attribution tuning ----------------------------------------------------
TIMEZONE=America/Denver
INTERNAL_DOMAINS=ashfordsky.com
FREEMAIL_DOMAINS=gmail.com,yahoo.com,outlook.com,hotmail.com,icloud.com,aol.com
AUTO_FINALIZE_THRESHOLD=0.85
REVIEW_THRESHOLD=0.5
MIN_INTERVAL_SECONDS=5
# One idle stretch longer than this (seconds) = "away" — never billed, and not
# counted as on-computer idle (so a lunch with an app left open isn't "at desk").
AWAY_CUTOFF_SECONDS=1800
# A no-input stretch shorter than this counts as working (a pause at the desk —
# reading, thinking, listening on a call), not idle. ActivityWatch flags AFK at
# ~3 min; this raises the effective idle threshold to 10 min in our pipeline.
IDLE_GRACE_SECONDS=600

# ---- Screenshots (OFF by default) ------------------------------------------
SCREENSHOTS_ENABLED=false
SCREENSHOT_DIR=./.data/screenshots
SCREENSHOT_STABLE_SECONDS=20
SCREENSHOT_RETENTION_DAYS=14

# ---- LLM resolver (OFF by default) -----------------------------------------
# Final pass over the blocks the deterministic rules can't place (unresolved, or
# ambiguous AI/dev/email time). Reads each block's title + on-screen OCR + nearest
# client and decides: a client (always written as "suggested" for you to confirm —
# never auto-billed), a non-billable category (incl. firm tool-building), or
# unknown. Runs locally in the sync only; the key is NOT needed on Railway.
LLM_ENABLED=false
ANTHROPIC_API_KEY=__paste_anthropic_api_key_here__
# Default is Opus 4.8. Set to claude-haiku-4-5 to cut per-block cost ~5x.
LLM_MODEL=claude-opus-4-8
# Safety cap: most residual blocks classified per sync run (longest first).
LLM_MAX_BLOCKS=120

# ---- Teammate agent (token mode) -------------------------------------------
# For a TEAMMATE'S machine only. In this mode the machine has NO database access:
# it sends activity to the dashboard's /api/ingest with a per-person token.
# `scripts\setup-agent.ps1` writes these for them; shown here for reference.
# A teammate .env has NO DATABASE_URL — just the four lines below.
#   INGEST_URL=https://<your-dashboard>/api/ingest
#   INGEST_TOKEN=ttk_...        # from `mint-token`, given to them by the admin
#   ACTIVITYWATCH_URL=http://localhost:5600
#   TIMEZONE=America/Denver

# ---- Dashboard auth: Microsoft 365 (Entra ID) login ------------------------
# Locks the dashboard to firm M365 accounts. REQUIRED on any public deploy
# (e.g. Railway) — without these the site fails closed (HTTP 503). Create an
# App Registration: Azure Portal > Microsoft Entra ID > App registrations > New.
#   Redirect URI (Web): https://<your-domain>/api/auth/callback/microsoft-entra-id
#   (add http://localhost:3000/api/auth/callback/microsoft-entra-id for local dev)
#   Then: Certificates & secrets > New client secret (copy the *Value*).
# Public URL of the deployment. REQUIRED behind a proxy (Railway/containers) or
# Auth.js builds sign-in/callback URLs from the container's localhost:$PORT. No
# trailing slash. Local dev: http://localhost:3000
AUTH_URL=https://your-app.up.railway.app
AUTH_SECRET=__generate: `openssl rand -base64 32` (or any 32+ random chars)__
AUTH_MICROSOFT_ENTRA_ID_ID=__application (client) id__
AUTH_MICROSOFT_ENTRA_ID_SECRET=__client secret VALUE__
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/__tenant-id__/v2.0
AUTH_ALLOWED_DOMAIN=ashfordsky.com
# Escape hatch — run with NO auth (local dev only; never set on a public deploy):
# DASHBOARD_PUBLIC=true
